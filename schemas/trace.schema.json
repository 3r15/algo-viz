{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://algo-viz/schemas/trace.schema.json",
  "title": "Algorithm Trace",
  "description": "생성 방식(Model A / Model 2)과 무관하게 두 모델이 동일하게 산출해야 하는 트레이스 계약.",
  "type": "array",
  "minItems": 1,
  "items": { "$ref": "#/$defs/step" },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["line", "op", "values", "sortedFrom", "explain"],
      "properties": {
        "line": { "type": "integer", "minimum": 1,
          "description": "표시 소스에서 이 스텝이 실행하는 줄 번호(코드 하이라이트 대상)" },
        "op": { "type": "string",
          "description": "start|compare|swap|pass-end|done 등. 커스텀 op 은 전용 렌더러 필요",
          "examples": ["start", "compare", "swap", "pass-end", "done", "visit", "push", "pop"] },
        "values": { "type": "array", "items": { "type": "number" },
          "description": "이 스텝 직후의 자료구조 스냅샷(되감기의 근거)" },
        "sortedFrom": { "type": "integer", "minimum": 0,
          "description": "이 인덱스부터 확정/정렬됨(초록 표시). 없으면 values.length" },
        "explain": { "type": "string", "description": "현재 줄에 동기화된 한 줄 설명" },
        "i": { "type": "integer" },
        "j": { "type": "integer" },
        "a": { "type": "integer", "description": "연산에 관여한 인덱스 A(없으면 -1)" },
        "b": { "type": "integer", "description": "연산에 관여한 인덱스 B(없으면 -1)" },
        "scope": { "type": "string", "description": "함수/호출 문맥(선택)" },
        "locals": { "type": "object", "description": "지역 변수 스냅샷(선택)" }
      },
      "additionalProperties": true
    }
  }
}
